{
  "name": "tesslate-ast",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Stateless gRPC service that performs JSX/TSX AST operations for the Tesslate Studio design view. Bytes in, bytes out.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "test": "tsc && node --test 'dist/test/*.spec.js'"
  },
  "dependencies": {
    "@babel/generator": "^7.24.7",
    "@babel/parser": "^7.24.7",
    "@babel/traverse": "^7.24.7",
    "@babel/types": "^7.24.7",
    "@grpc/grpc-js": "^1.10.9",
    "nanoid": "^5.0.7",
    "piscina": "^4.6.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}

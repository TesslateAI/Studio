# Tesslate Dev Server Image
# Universal Alpine-based image supporting Node.js, Python, and Go
# Pre-installed dependencies for fast user environment startup
# Used by both Docker (local) and Kubernetes (production) deployment modes
# - K8s: Built and pushed to registry via k8s/scripts/deployment/build-push-images.sh
# - Docker: Built on-demand by docker_container_manager.py from this file

# --- Build tsinit (container process supervisor) ---
FROM golang:1.22-alpine AS init-builder
WORKDIR /src
COPY services/tsinit/go.mod services/tsinit/go.sum ./
RUN go mod download
COPY services/tsinit/ .
RUN CGO_ENABLED=0 go build -ldflags "-s -w" -o /tsinit .

FROM node:24-alpine

# Install system dependencies for Node.js, Python, and Go development.
# - zip/unzip: project archiving (S3 ops handled securely by backend)
# - openssl: Prisma 5.x's runtime probe execs ``openssl version`` to pick its
#   query-engine binary; without it Prisma defaults to "openssl-1.1.x" and
#   then crashes loading libssl 1.1 (which Alpine doesn't ship). Alpine 3.20+
#   already has /usr/lib/libssl.so.3, but Prisma needs the CLI to detect it.
RUN apk add --no-cache \
    git \
    git-lfs \
    curl \
    openssl \
    python3 \
    py3-pip \
    make \
    g++ \
    go \
    bash \
    zip \
    unzip

# tsinit: container process supervisor (replaces tmux)
COPY --from=init-builder /tsinit /usr/local/bin/tsinit

# Set up Go environment
ENV GOPATH=/go
ENV PATH=$PATH:/go/bin
RUN mkdir -p /go/bin

# Allow pip to install packages globally (needed for FastAPI bases)
# This is safe because the container is ephemeral
ENV PIP_BREAK_SYSTEM_PACKAGES=1
# Ensure pip-installed scripts (uvicorn, gunicorn, etc.) are on PATH
ENV PATH="/home/node/.local/bin:$PATH"

# Install Air for Go hot reloading (latest version)
RUN go install github.com/air-verse/air@latest

# Install bun globally (fastest package manager, creates flat node_modules)
# Install to /usr/local/bin so it's available for all users.
# pipefail + version postcheck: if the curl ever returns empty (transient
# DNS/network), the layer would otherwise commit without bun and fail at
# runtime with `bun: not found`. Fail the build instead.
RUN set -o pipefail \
 && curl -fsSL https://bun.sh/install | BUN_INSTALL=/usr/local bash \
 && /usr/local/bin/bun --version
ENV PATH="/usr/local/bin:$PATH"

# Install common global npm packages for development
RUN npm install -g pnpm typescript vite create-vite eslint prettier

# Create project directory (will be mounted/populated at runtime)
WORKDIR /project

# Set ownership for non-root user (uid 1000)
# This matches the security context used in both Docker and K8s deployments
RUN chown -R 1000:1000 /project

# Switch to non-root user for security
USER 1000

# Metadata
LABEL maintainer="OpenSail"
LABEL description="Development server image with Node.js, Python, and Go support"
LABEL version="2.0"

# Health check (optional, for container monitoring)
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD node --version || exit 1

# Default command (will be overridden by deployment configuration)
CMD ["sh", "-c", "echo 'Tesslate dev server ready' && sleep infinity"]

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ContactStatus {
  lead
  customer
  lost
}

enum ActivityKind {
  created
  updated
  note_added
  agent_action
}

model Contact {
  id        String        @id @default(cuid())
  name      String
  email     String        @unique
  company   String?
  phone     String?
  status    ContactStatus @default(lead)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  notes      Note[]
  activities Activity[]
}

model Note {
  id        String   @id @default(cuid())
  contactId String
  body      String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String       @id @default(cuid())
  contactId String
  kind      ActivityKind
  details   String
  createdAt DateTime     @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

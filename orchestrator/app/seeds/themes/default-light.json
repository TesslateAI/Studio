{
  "id": "default-light",
  "name": "Default Light",
  "mode": "light",
  "author": "Tesslate",
  "version": "1.0.0",
  "description": "The default Tesslate light theme with orange accents",
  "category": "general",
  "tags": ["light", "default", "clean"],
  "icon": "sun",
  "borderless": true,

  "colors": {
    "primary": "#F89521",
    "primaryHover": "#e88a1d",
    "primaryRgb": "248, 149, 33",
    "accent": "#0891b2",

    "background": "#F5F6F7",
    "surface": "#ffffff",
    "surfaceHover": "#f3f4f6",

    "text": "#1a1a1a",
    "textMuted": "#4b5563",
    "textSubtle": "#6b7280",

    "border": "#e5e7eb",
    "borderHover": "#d1d5db",

    "sidebar": {
      "background": "#ffffff",
      "text": "#1a1a1a",
      "border": "#e5e7eb",
      "hover": "#f3f4f6",
      "active": "rgba(248, 149, 33, 0.15)"
    },

    "input": {
      "background": "#ffffff",
      "border": "#d1d5db",
      "borderFocus": "#F89521",
      "text": "#1a1a1a",
      "placeholder": "#9ca3af"
    },

    "scrollbar": {
      "thumb": "#d1d5db",
      "thumbHover": "#9ca3af",
      "track": "transparent"
    },

    "code": {
      "inlineBackground": "rgba(248, 149, 33, 0.1)",
      "inlineText": "#c2570b",
      "blockBackground": "#f3f4f6",
      "blockBorder": "#e5e7eb",
      "blockText": "#374151"
    },

    "status": {
      "error": "#b91c1c",
      "errorRgb": "185, 28, 28",
      "success": "#15803d",
      "successRgb": "21, 128, 61",
      "warning": "#b45309",
      "warningRgb": "180, 83, 9",
      "info": "#1d4ed8",
      "infoRgb": "29, 78, 216"
    },

    "shadow": {
      "small": "0 1px 2px rgba(0, 0, 0, 0.05)",
      "medium": "0 4px 6px rgba(0, 0, 0, 0.07)",
      "large": "0 10px 15px rgba(0, 0, 0, 0.1)"
    }
  },

  "typography": {
    "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "fontFamilyMono": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "fontSizeBase": "14px",
    "lineHeight": "1.5"
  },

  "spacing": {
    "radiusSmall": "4px",
    "radiusMedium": "6px",
    "radiusLarge": "8px",
    "radiusXl": "12px"
  },

  "animation": {
    "durationFast": "150ms",
    "durationNormal": "200ms",
    "durationSlow": "300ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  }
}

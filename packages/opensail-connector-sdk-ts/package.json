{
  "name": "@opensail/connector-sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript SDK for calling third-party providers (Slack, GitHub, Linear, Gmail) through the OpenSail Connector Proxy from inside an installed app.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.11.0"
  },
  "license": "Apache-2.0"
}

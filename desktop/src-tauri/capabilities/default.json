{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Baseline capabilities for the OpenSail desktop shell",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    "shell:allow-spawn",
    "dialog:default",
    "fs:default",
    "notification:default",
    "deep-link:default",
    "updater:default"
  ]
}

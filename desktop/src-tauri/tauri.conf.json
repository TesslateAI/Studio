{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenSail",
  "version": "0.1.0",
  "identifier": "com.tesslate.studio",
  "build": {
    "frontendDist": "../../app/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ../app dev",
    "beforeBuildCommand": "pnpm --dir ../app build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://your-domain.com/desktop/releases/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3NkI1RkE5NTIyMTVBMDgKUldRSVdpRlNxVjlyUjBhWldpVy9mdTJuZ0FuY1NyczdLMi9jcE5xc0c1dnhYSHNJVWxHNHArSVgK",
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": ["binaries/tesslate-studio-orchestrator"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

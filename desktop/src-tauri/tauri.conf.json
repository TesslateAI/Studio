{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenSail",
  "version": "0.1.0",
  "identifier": "com.tesslate.studio",
  "build": {
    "frontendDist": "../../app/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ../app dev",
    "beforeBuildCommand": "pnpm --dir ../app build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenSail",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 20, "y": 20 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://opensail.tesslate.com/desktop/releases/latest.json"],
      "pubkey": "PLACEHOLDER — replace with output of `cargo tauri signer generate` once the release keypair is created; store the private key as CI secret TAURI_SIGNING_PRIVATE_KEY",
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/tesslate-studio-orchestrator"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

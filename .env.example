# ============================================================================
# Tesslate Studio - Quick Start Configuration
# ============================================================================
# This is for Docker Compose quick start only
# For detailed configuration, use service-specific .env files:
#   - orchestrator/.env.example  : Backend configuration
#   - app/.env.example           : Frontend configuration
#   - k8s/.env.example           : Kubernetes deployment
# ============================================================================

# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Update SECRET_KEY and OPENAI_API_KEY below
# 3. Run: docker compose up -d
# 4. Never commit the .env file to version control

# ----------------------------------------------------------------------------
# Required Configuration
# ----------------------------------------------------------------------------

# Backend Secret Key (IMPORTANT: Change in production!)
SECRET_KEY=your-secret-key-here-change-this-in-production

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here

# ----------------------------------------------------------------------------
# Optional Configuration (has sensible defaults)
# ----------------------------------------------------------------------------

# Database (default: SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./builder.db

# OpenAI API Base URL (default: https://api.openai.com/v1)
# Change this to use alternative OpenAI-compatible APIs (e.g., Cerebras, Azure OpenAI)
# OPENAI_API_BASE=https://api.openai.com/v1

# AI Model (default: gpt-3.5-turbo)
# For OpenAI: gpt-3.5-turbo, gpt-4, gpt-4-turbo
# For Cerebras (with custom OPENAI_API_BASE): cerebras/llama3.1-8b, cerebras/llama3.1-70b
# OPENAI_MODEL=gpt-3.5-turbo

# Deployment Mode (default: docker)
# Options: "docker" (local development) or "kubernetes" (production cluster)
# DEPLOYMENT_MODE=docker

# ----------------------------------------------------------------------------
# Dev Container URL Configuration
# ----------------------------------------------------------------------------
# Controls how user dev containers are accessed
#
# Docker Mode (Local Development):
#   - Leave empty for hostname-based routing
#   - URLs: http://user2-project15.localhost
#   - Requires Traefik running on port 80
#
# Docker Mode (Production with Wildcard DNS):
#   - Set to your production domain: https://studio-demo.tesslate.com
#   - URLs: https://user2-project15.studio-demo.tesslate.com
#   - Requires:
#     * Wildcard DNS: *.studio-demo.tesslate.com → your server
#     * Cloudflare proxy OR wildcard SSL certificate
#     * Traefik configured for wildcard routing
#
# Default: Empty (local development)
# DEV_SERVER_BASE_URL=https://studio-demo.tesslate.com

# ----------------------------------------------------------------------------
# CORS and Security Configuration
# ----------------------------------------------------------------------------

# CORS Allowed Origins (comma-separated list)
# Add all frontend URLs that should be allowed to access the API
# For local development, include localhost ports
# For production, include your production domain(s)
#
# Note: For Docker mode with hostname routing, *.localhost domains are
# automatically allowed via regex pattern. No need to explicitly list them.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000,https://studio-test.tesslate.com,https://studio-demo.tesslate.com

# Allowed Hosts (comma-separated list)
# List of hostnames allowed for Vite dev server and Content Security Policy
# Use *.localhost for wildcard local subdomain support
ALLOWED_HOSTS=your-domain.com,studio-test.tesslate.com,studio-demo.tesslate.com,localhost,*.localhost

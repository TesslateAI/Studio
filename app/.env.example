# ============================================================================
# Tesslate Studio Frontend Configuration
# ============================================================================
# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Update the value below (usually leave empty)
# 3. Never commit the .env file to version control
# ============================================================================

# ----------------------------------------------------------------------------
# API URL Configuration
# ----------------------------------------------------------------------------
# The backend API URL the frontend should connect to
#
# Docker Compose (Recommended):
#   VITE_API_URL=
#   (Empty uses Vite proxy which connects to orchestrator service in Docker)
#
# Native Development - Direct backend connection:
#   VITE_API_URL=http://localhost:8000
#
# Production - Different domain:
#   VITE_API_URL=https://api.yourdomain.com
#
VITE_API_URL=http://studio.localhost

# ----------------------------------------------------------------------------
# Allowed Hosts Configuration
# ----------------------------------------------------------------------------
# Comma-separated list of hostnames allowed to access the Vite dev server
# Used for Host header validation and security
#
# Default (leave commented for sensible defaults):
#   your-domain.com,studio-test.tesslate.com,studio-demo.tesslate.com,localhost,host.docker.internal,.localhost
#
# Add custom domains:
#   VITE_ALLOWED_HOSTS=yourdomain.com,*.yourdomain.com,localhost,.localhost
#
# VITE_ALLOWED_HOSTS=your-domain.com,studio-test.tesslate.com,studio-demo.tesslate.com,localhost,host.docker.internal,.localhost
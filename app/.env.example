# ============================================================================
# Tesslate Studio Frontend Configuration
# ============================================================================
# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Update the value below (usually leave empty)
# 3. Never commit the .env file to version control
# ============================================================================

# ----------------------------------------------------------------------------
# API URL Configuration
# ----------------------------------------------------------------------------
# The backend API URL the frontend should connect to
#
# Most Common (Recommended):
#   VITE_API_URL=
#   (Empty uses relative paths through Vite proxy or same-domain routing)
#
# Alternative - Direct backend connection:
#   VITE_API_URL=http://localhost:8000
#
# Production - Different domain:
#   VITE_API_URL=https://api.yourdomain.com
#
VITE_API_URL=
# ============================================================================
# Application Secrets Template for Kubernetes
# ============================================================================
#
# IMPORTANT: This is a template file. DO NOT use these values in production!
#
# Instructions:
# 1. Copy this file: cp app-secrets.yaml.example app-secrets.yaml
# 2. Replace ALL placeholder values with actual secrets
# 3. Never commit app-secrets.yaml to version control
# 4. Use strong, randomly generated values for all secrets
# 5. Rotate secrets regularly (every 90 days minimum)
#
# Quick Generation Script:
# Run: cd k8s && bash generate-secrets.sh yourdomain.com your-email@domain.com
#
# Manual Secret Generation:
# - SECRET_KEY: openssl rand -base64 64
# - CSRF_SECRET_KEY: openssl rand -base64 32
# - Database Password: openssl rand -base64 32
#
# ============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: tesslate-app-secrets
  namespace: tesslate
  labels:
    app: tesslate
    component: security
type: Opaque
stringData:
  # ===== CORE APPLICATION SECRETS =====
  SECRET_KEY: "REPLACE_WITH_SECRET_KEY"
  CSRF_SECRET_KEY: "REPLACE_WITH_CSRF_SECRET_KEY"

  # ===== DATABASE CONNECTION =====
  DATABASE_URL: "postgresql+asyncpg://tesslate_user:REPLACE_WITH_DB_PASSWORD@postgres.tesslate.svc.cluster.local:5432/tesslate"

  # ===== LITELLM CONFIGURATION =====
  LITELLM_API_BASE: "https://apin.tesslate.com/v1"
  LITELLM_MASTER_KEY: "REPLACE_WITH_LITELLM_KEY"
  LITELLM_DEFAULT_MODELS: "gpt-4o-mini,gpt-4o,gpt-3.5-turbo,claude-3-opus,claude-3-sonnet"
  LITELLM_TEAM_ID: "default"
  LITELLM_EMAIL_DOMAIN: "yourdomain.com"
  LITELLM_INITIAL_BUDGET: "10.0"

  # ===== DOMAIN CONFIGURATION =====
  APP_DOMAIN: "yourdomain.com"
  APP_PROTOCOL: "https"
  CORS_ORIGINS: "https://yourdomain.com"
  ALLOWED_HOSTS: "yourdomain.com,*.yourdomain.com"
  COOKIE_DOMAIN: "yourdomain.com"
  COOKIE_SECURE: "true"
  COOKIE_SAMESITE: "lax"

  # ===== DEPLOYMENT MODE =====
  DEPLOYMENT_MODE: "kubernetes"

  # ===== AGENT RESOURCE LIMITS =====
  AGENT_MAX_COST: "20.0"
  AGENT_MAX_ITERATIONS: "100"
  AGENT_MAX_COST_PER_RUN: "5.0"

  # ===== CONTAINER CLEANUP =====
  CONTAINER_CLEANUP_INTERVAL_MINUTES: "2"
  CONTAINER_CLEANUP_TIER1_IDLE_MINUTES: "15"
  CONTAINER_CLEANUP_TIER2_PAUSED_HOURS: "24"

  # ===== KUBERNETES CONFIGURATION =====
  K8S_PVC_STORAGE_CLASS: "do-block-storage"
  K8S_PVC_SIZE: "5Gi"
  K8S_PVC_ACCESS_MODE: "ReadWriteOnce"
  K8S_NAMESPACE_PER_PROJECT: "true"
  K8S_ENABLE_NETWORK_POLICIES: "true"
  K8S_RWX_STORAGE_CLASS: "nfs-client"

  # ===== S3/DIGITALOCEAN SPACES CONFIGURATION (OPTIONAL - for S3-backed ephemeral storage) =====
  # Enable S3-backed storage for hibernation/hydration model
  # When enabled, projects are stored in S3 when pods are deleted, and restored when pods start
  K8S_USE_S3_STORAGE: "false"

  # DigitalOcean Spaces credentials (S3-compatible)
  # Generate from: DigitalOcean Dashboard > API > Spaces access keys
  S3_ACCESS_KEY_ID: ""
  S3_SECRET_ACCESS_KEY: ""
  S3_BUCKET_NAME: "tesslate-projects"
  S3_ENDPOINT_URL: "https://nyc3.digitaloceanspaces.com"
  S3_REGION: "us-east-1"
  S3_PROJECTS_PREFIX: "projects"

  # Hibernation/Hydration timeouts (only used when K8S_USE_S3_STORAGE=true)
  K8S_HIBERNATION_IDLE_MINUTES: "30"
  K8S_HYDRATION_TIMEOUT_SECONDS: "300"
  K8S_DEHYDRATION_TIMEOUT_SECONDS: "120"

  # ===== OAUTH CONFIGURATION (OPTIONAL) =====
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""
  GOOGLE_OAUTH_REDIRECT_URI: "https://yourdomain.com/api/auth/google/callback"
  GITHUB_CLIENT_ID: ""
  GITHUB_CLIENT_SECRET: ""
  GITHUB_OAUTH_REDIRECT_URI: "https://yourdomain.com/api/auth/github/callback"

  # ===== DEPLOYMENT PROVIDER OAUTH (OPTIONAL) =====
  VERCEL_CLIENT_ID: ""
  VERCEL_CLIENT_SECRET: ""
  VERCEL_OAUTH_REDIRECT_URI: "https://yourdomain.com/api/deployment-oauth/vercel/callback"
  NETLIFY_CLIENT_ID: ""
  NETLIFY_CLIENT_SECRET: ""
  NETLIFY_OAUTH_REDIRECT_URI: "https://yourdomain.com/api/deployment-oauth/netlify/callback"

  # ===== DEPLOYMENT CONFIGURATION =====
  DEPLOYMENT_ENCRYPTION_KEY: ""
  DEPLOYMENT_TIMEOUT: "600"
  DEPLOYMENT_BUILD_DIR: "dist"
  CLOUDFLARE_API_BASE: "https://api.cloudflare.com/client/v4"
  VERCEL_API_BASE: "https://api.vercel.com"
  NETLIFY_API_BASE: "https://api.netlify.com/api/v1"

  # ===== STRIPE PAYMENT INTEGRATION (OPTIONAL) =====
  STRIPE_SECRET_KEY: ""
  STRIPE_PUBLISHABLE_KEY: ""
  STRIPE_WEBHOOK_SECRET: ""
  STRIPE_CONNECT_CLIENT_ID: ""
  STRIPE_PREMIUM_PRICE_ID: ""

  # ===== SUBSCRIPTION PRICING =====
  PREMIUM_SUBSCRIPTION_PRICE: "500"
  CREDIT_PACKAGE_SMALL: "500"
  CREDIT_PACKAGE_MEDIUM: "1500"
  CREDIT_PACKAGE_LARGE: "2500"
  ADDITIONAL_DEPLOY_PRICE: "1000"

  # ===== SUBSCRIPTION TIER LIMITS =====
  FREE_MAX_PROJECTS: "1"
  FREE_MAX_DEPLOYS: "1"
  FREE_INITIAL_CREDITS: "0"
  PREMIUM_MAX_PROJECTS: "5"
  PREMIUM_MAX_DEPLOYS: "5"
  PREMIUM_INITIAL_CREDITS: "0"

  # ===== REVENUE SHARING =====
  CREATOR_REVENUE_SHARE: "0.90"
  PLATFORM_REVENUE_SHARE: "0.10"

  # ===== BILLING SETTINGS =====
  USAGE_INVOICE_DAY: "1"

  # ===== ANALYTICS (OPTIONAL) =====
  VITE_PUBLIC_POSTHOG_KEY: ""
  VITE_PUBLIC_POSTHOG_HOST: ""

# ============================================================================
# SECURITY CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
# [ ] All REPLACE_WITH_* values have been replaced
# [ ] SECRET_KEY is at least 64 characters (generated with openssl rand -base64 64)
# [ ] CSRF_SECRET_KEY is at least 32 characters
# [ ] Database password matches postgres-secret.yaml
# [ ] LITELLM_MASTER_KEY is valid and configured
# [ ] Domain (APP_DOMAIN) is set to your actual domain
# [ ] CORS_ORIGINS and ALLOWED_HOSTS include your domain
# [ ] COOKIE_SECURE is "true" for production (HTTPS only)
# [ ] OAuth credentials are valid (if using Google/GitHub login)
# [ ] Stripe keys are valid (if using payments)
# [ ] File permissions are restricted (chmod 600)
# [ ] This file is NOT committed to version control
# [ ] Backup of secrets stored in secure location (password manager/vault)
# [ ] Secret rotation schedule documented
#
# If using S3-backed ephemeral storage (K8S_USE_S3_STORAGE=true):
# [ ] S3_ACCESS_KEY_ID and S3_SECRET_ACCESS_KEY are set
# [ ] S3_BUCKET_NAME exists and is accessible
# [ ] S3_ENDPOINT_URL points to correct endpoint (e.g., nyc3.digitaloceanspaces.com)
# [ ] s3-credentials secret created (for init containers)
# ============================================================================

# ============================================================================
# S3/DigitalOcean Spaces Credentials Secret Template
# ============================================================================
#
# This secret is used by init containers for hydration (S3 download) and
# lifecycle hooks for dehydration (S3 upload) in the S3-backed ephemeral
# architecture.
#
# IMPORTANT: This is a template file. DO NOT use these values in production!
#
# Instructions:
# 1. Copy this file: cp s3-credentials.yaml.example s3-credentials.yaml
# 2. Replace ALL placeholder values with actual credentials
# 3. Never commit s3-credentials.yaml to version control
# 4. Ensure this matches S3 values in app-secrets.yaml
#
# Getting DigitalOcean Spaces Credentials:
# 1. Go to DigitalOcean Dashboard > API > Spaces access keys
# 2. Create a new access key
# 3. Copy the Access Key ID and Secret Access Key
# 4. Note: Secret is only shown once during creation
#
# ============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: s3-credentials
  namespace: tesslate
  labels:
    app: tesslate
    component: storage
    purpose: s3-ephemeral-storage
type: Opaque
stringData:
  # DigitalOcean Spaces / AWS S3 Access Key
  # Generate from: DigitalOcean Dashboard > API > Spaces access keys
  S3_ACCESS_KEY_ID: "REPLACE_WITH_SPACES_ACCESS_KEY"

  # DigitalOcean Spaces / AWS S3 Secret Key
  # Only shown once during key creation - store securely!
  S3_SECRET_ACCESS_KEY: "REPLACE_WITH_SPACES_SECRET_KEY"

---
# ============================================================================
# USAGE NOTES
# ============================================================================
#
# This secret is mounted as environment variables in:
# 1. Init containers (hydrate-project) for downloading project from S3
# 2. Main containers via preStop lifecycle hook for uploading to S3
#
# The init container script uses these variables:
#   export AWS_ACCESS_KEY_ID="${S3_ACCESS_KEY_ID}"
#   export AWS_SECRET_ACCESS_KEY="${S3_SECRET_ACCESS_KEY}"
#
# Required for S3-backed ephemeral storage mode (K8S_USE_S3_STORAGE=true)
#
# Apply with:
#   kubectl apply -f k8s/manifests/security/s3-credentials.yaml
#
# Verify:
#   kubectl get secret s3-credentials -n tesslate -o yaml
#
# ============================================================================

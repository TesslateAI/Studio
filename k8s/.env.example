# ============================================================================
# Tesslate Studio - Kubernetes Environment Configuration
# ============================================================================
# Copy this file to:
#   - k8s/.env.minikube  (for local development)
#   - k8s/.env.production (for production deployment)
#
# Then run: ./scripts/generate-secrets-from-env.sh [minikube|production]
# ============================================================================

# ----------------------------------------------------------------------------
# Environment Type
# ----------------------------------------------------------------------------
K8S_ENVIRONMENT=minikube

# ----------------------------------------------------------------------------
# Domain Configuration
# ----------------------------------------------------------------------------
# For minikube: localhost
# For production: your-domain.com
APP_DOMAIN=localhost
APP_PROTOCOL=http

# Email for Let's Encrypt SSL certificates (production only)
SSL_EMAIL=

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
POSTGRES_DB=tesslate_dev
POSTGRES_USER=tesslate_user
POSTGRES_PASSWORD=your-postgres-password-here

# ----------------------------------------------------------------------------
# Application Secret Key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here

# ----------------------------------------------------------------------------
# LiteLLM Configuration (Required for AI features)
# ----------------------------------------------------------------------------
LITELLM_API_BASE=https://your-litellm-instance.com/v1
LITELLM_MASTER_KEY=your-litellm-master-key
LITELLM_DEFAULT_MODELS=gpt-4o-mini
LITELLM_TEAM_ID=default
LITELLM_EMAIL_DOMAIN=localhost
LITELLM_INITIAL_BUDGET=10.0

# ----------------------------------------------------------------------------
# OAuth Configuration (Optional - leave empty to disable)
# ----------------------------------------------------------------------------
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=

# ----------------------------------------------------------------------------
# Stripe Payment Configuration (Optional)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=

# Pricing (in cents)
PREMIUM_SUBSCRIPTION_PRICE=500
CREDIT_PACKAGE_SMALL=500
CREDIT_PACKAGE_MEDIUM=1000
CREDIT_PACKAGE_LARGE=5000

# User Limits
FREE_MAX_PROJECTS=1
PREMIUM_MAX_PROJECTS=5

# ----------------------------------------------------------------------------
# S3/MinIO Configuration (for project hibernation)
# ----------------------------------------------------------------------------
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=tesslate-projects
S3_ENDPOINT_URL=http://minio.minio-system.svc.cluster.local:9000
S3_REGION=us-east-1

# ----------------------------------------------------------------------------
# PostHog Analytics (Optional)
# ----------------------------------------------------------------------------
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

# ----------------------------------------------------------------------------
# Cookie Security
# ----------------------------------------------------------------------------
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.localhost

# ----------------------------------------------------------------------------
# Container Registry (Production only)
# ----------------------------------------------------------------------------
DOCR_TOKEN=

{
  "manifest_schema_version": "2025-02",
  "app": {
    "id": "com.tesslate.digest",
    "slug": "nightly-digest",
    "name": "Nightly Activity Digest",
    "version": "0.1.0",
    "description": "Headless cron-triggered digest that summarizes CRM activity each night via Llama.",
    "category": "automation",
    "forkable": "true"
  },
  "compatibility": {
    "studio": {"min": "0.0.0"},
    "manifest_schema": "2025-02",
    "runtime_api": "^1.0",
    "required_features": []
  },
  "compute": {
    "tier": 0,
    "model": "job-only",
    "compute_model": "shared-singleton",
    "containers": [
      {
        "name": "runner",
        "primary": true,
        "image": "tesslate-devserver:latest",
        "startup_command": "sh -c 'cd /app && (test -d node_modules || npm install) && tail -f /dev/null'",
        "env": {
          "LLAMA_API_BASE": "https://api.llama.com/compat/v1/",
          "LLAMA_MODEL": "Llama-4-Maverick-17B-128E-Instruct-FP8",
          "LLAMA_API_KEY": "${secret:llama-api-credentials/api_key}"
        }
      }
    ],
    "connections": []
  },
  "surfaces": [],
  "schedules": [
    {
      "name": "nightly",
      "default_cron": "0 2 * * *",
      "execution": "job",
      "entrypoint": "node /app/scripts/digest.js",
      "editable": true,
      "optional": false
    }
  ],
  "state": {"model": "per-install-volume", "volume_size": "500Mi"},
  "billing": {
    "ai_compute": {"payer": "platform"},
    "general_compute": {"payer": "platform"},
    "platform_fee": {"model": "free"}
  },
  "listing": {"visibility": "public"}
}

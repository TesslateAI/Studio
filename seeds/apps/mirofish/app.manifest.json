{
  "manifest_schema_version": "2025-02",
  "app": {
    "id": "com.666ghj.mirofish",
    "slug": "mirofish",
    "name": "MiroFish",
    "version": "0.2.2",
    "description": "Swarm-intelligence multi-agent prediction engine. Uploads a seed report or novel, runs thousands of persona-driven agents in a simulated world, and returns a prediction report. Requires an OpenAI-compatible LLM API key.",
    "category": "research",
    "forkable": "restricted"
  },
  "compatibility": {
    "studio": {
      "min": "0.0.0"
    },
    "manifest_schema": "2025-02",
    "runtime_api": "^1.0",
    "required_features": []
  },
  "compute": {
    "tier": 2,
    "model": "always-on",
    "compute_model": "per-installer",
    "containers": [
      {
        "name": "web",
        "primary": true,
        "image": "ghcr.io/666ghj/mirofish:latest",
        "source_strategy": "image",
        "ports": [
          3000,
          5001
        ],
        "startup_command": "sh -c 'chmod -R u+w /app/backend/.venv 2>/dev/null || true; npm run dev'",
        "env": {
          "LLM_API_KEY": "${secret:llama-api-credentials/api_key}",
          "LLM_BASE_URL": "https://api.llama.com/compat/v1/",
          "LLM_MODEL_NAME": "Llama-4-Maverick-17B-128E-Instruct-FP8",
          "ZEP_API_KEY": "${secret:zep-credentials/api_key}",
          "UV_NO_CACHE": "1"
        }
      }
    ],
    "connections": [],
    "credentials": [
      {
        "secret_ref": "zep-credentials/api_key",
        "label": "Zep API Key",
        "description": "Memory graph service — get a free key at https://app.getzep.com/",
        "required": true
      }
    ]
  },
  "surfaces": [
    {
      "kind": "ui",
      "entrypoint": "/"
    }
  ],
  "state": {
    "model": "per-install-volume",
    "volume_size": "10Gi",
    "mount_path": "/data"
  },
  "billing": {
    "ai_compute": {
      "payer": "installer",
      "markup_pct": 0
    },
    "general_compute": {
      "payer": "installer"
    },
    "platform_fee": {
      "model": "free"
    }
  },
  "listing": {
    "visibility": "public"
  }
}

{
  "manifest_schema_version": "2025-02",
  "app": {
    "id": "com.tesslate.crm",
    "slug": "crm-demo",
    "name": "Tesslate CRM",
    "version": "0.1.2",
    "description": "A minimal CRM demo with a chat-drawer agent running on the Tesslate Apps runtime.",
    "category": "productivity",
    "forkable": "true"
  },
  "compatibility": {
    "studio": {
      "min": "0.0.0"
    },
    "manifest_schema": "2025-02",
    "runtime_api": "^1.0",
    "required_features": []
  },
  "compute": {
    "tier": 1,
    "compute_model": "per-installer",
    "containers": [
      {
        "name": "web",
        "primary": true,
        "image": "tesslate-devserver:latest",
        "ports": [
          3000
        ],
        "startup_command": "sh -c 'cd /app && (test -d node_modules || npm install) && npx prisma migrate deploy || npx prisma db push --skip-generate --accept-data-loss; npm run build && node .next/standalone/server.js'",
        "env": {
          "NODE_ENV": "production",
          "DATABASE_URL": "file:/app/data/crm.db",
          "LLAMA_API_BASE": "https://api.llama.com/compat/v1/",
          "LLAMA_MODEL": "Llama-4-Maverick-17B-128E-Instruct-FP8",
          "LLAMA_API_KEY": "${secret:llama-api-credentials/api_key}"
        }
      }
    ],
    "connections": []
  },
  "surfaces": [
    {
      "kind": "ui",
      "entrypoint": "/"
    }
  ],
  "state": {
    "model": "per-install-volume",
    "volume_size": "2Gi"
  },
  "billing": {
    "ai_compute": {
      "payer": "installer",
      "markup_pct": 0
    },
    "general_compute": {
      "payer": "platform"
    },
    "platform_fee": {
      "model": "free"
    }
  },
  "listing": {
    "visibility": "public"
  }
}

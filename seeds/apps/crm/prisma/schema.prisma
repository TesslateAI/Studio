generator client {
  provider      = "prisma-client-js"
  // node:24-alpine ships OpenSSL 3.x. Prisma 5.x's runtime auto-detect
  // picks the legacy ``linux-musl`` engine (which links libssl 1.1) even
  // when the openssl-3.0 engine is on disk — and Alpine doesn't carry
  // libssl 1.1, so the first request fails with
  // ``Error loading shared library libssl.so.1.1``.
  //
  // We download BOTH engines (a singleton list silently no-ops the engine
  // download for unknown / new target names in 5.22.0) and the manifest
  // sets ``PRISMA_QUERY_ENGINE_LIBRARY`` to the openssl-3.0 binary so the
  // runtime bypasses detection entirely. ``native`` resolves to the
  // postinstall machine's target — in our container that's ``linux-musl``,
  // which is what triggers the download of the openssl-3.0 sibling target.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite doesn't support Prisma enums; use constrained strings instead.
// ContactStatus: "lead" | "customer" | "lost"
// ActivityKind:  "created" | "updated" | "note_added" | "agent_action"
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  company   String?
  phone     String?
  status    String   @default("lead")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes      Note[]
  activities Activity[]
}

model Note {
  id        String   @id @default(cuid())
  contactId String
  body      String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  contactId String
  kind      String
  details   String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}
